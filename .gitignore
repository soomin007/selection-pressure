# 의존성
node_modules/

# 빌드 산출물
dist/
*.local

# 시각 검증 스크린샷(boss-preview 기본 출력)
boss-preview.png

# 화면 소개 스크린샷 이미지(scripts/screenshots.mjs 출력 — 언제든 재생성). README(설명서)는 추적한다.
screenshots/*
!screenshots/README.md

# UI 디자인 목업 번들(claude.ai artifact export, 각 10MB+). 로컬 참조용 — 스펙은 docs/UI_HANDOFF.md 가 진실.
docs/적자생존 UI *.html

# 동시 세션 작업 조율판 (로컬 실시간 공유, 절대 커밋하지 않음)
ACTIVE_WORK.md

# 에디터/OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# 로그
*.log
npm-debug.log*

# 환경 변수
.env
.env.*
!.env.example
